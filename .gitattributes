# Force LF line endings for all files by default
* text=auto eol=lf

# Explicitly mark shell scripts as LF
*.sh text eol=lf
start-container text eol=lf
artisan text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
